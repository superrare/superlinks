root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# Supabase edge functions run in Deno, which uses 2-space indentation.
# Keep this scoped so formatters don't reflow the handler modules.
[supabase/functions/**.{ts,js,json}]
indent_style = space
indent_size = 2

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2
